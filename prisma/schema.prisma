// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Plan {
  id            Int            @id @default(autoincrement())
  name          String
  description   String         
  price         Decimal        @db.Decimal(10, 2)
  maxJobs       Int            
  maxAiResume   Int            
  maxAiSalary   Int            
  maxInterviews Int            
  recommended   Boolean        @default(false)
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}

enum WorkFormat {
  REMOTE
  HYBRID
  ONSITE
}

enum JobStatus {
  ACTIVE
  INACTIVE
}

enum ContractType {
  CLT
  PJ
  FREELANCER
}

enum JobType {
  STANDARD
  INTERNSHIP
  TRAINEE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AffirmativeType {
  NOT_INFORMED
  PCD
  WOMEN
  FIFTY_PLUS
  LGBTQIAPN
}

model Benefit {
  id   Int    @id @default(autoincrement())
  name String @unique
  jobs JobBenefit[]
}

model JobBenefit {
  jobId     Int
  benefitId Int

  job     Job     @relation(fields: [jobId], references: [id])
  benefit Benefit @relation(fields: [benefitId], references: [id])

  @@id([jobId, benefitId])
}

model Job {
  id            Int          @id @default(autoincrement())

  title         String
  description   String       @db.Text
  sectorId      Int
  positionId    Int

  status        JobStatus    @default(ACTIVE)
  contractType  ContractType
  jobType       JobType      @default(STANDARD)
  workFormat    WorkFormat
  workload      Int

  salary        Decimal?     @db.Decimal(10, 2)

  priority      Priority     @default(MEDIUM)
  visible       Boolean      @default(true)
  affirmative   AffirmativeType @default(NOT_INFORMED)
  deadline      DateTime?

  cep           String
  state         String
  city          String
  neighborhood  String
  address       String
  number        String
  complement    String?

  companyId     Int
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company       Company      @relation(fields: [companyId], references: [id])

  benefits      JobBenefit[]
  customBenefits String[]
}

model Sector {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  positions Position[]
}

model Position {
  id     Int    @id @default(autoincrement())
  name   String @unique
  sectorId Int
  sector   Sector   @relation(fields: [sectorId], references: [id])
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())

  employees   Int
  email       String
  phone       String
  site        String?
  cep         String
  address     String
  number      String
  complement  String?
  city        String
  state       String
  about       String
  cnpj        String @unique

  onboardingCompleted Boolean  @default(false)
  subscription        Subscription[]
  users               User[]
  usageRecords        UsageRecord[]
  jobs                Job[]
}

model Subscription {
  id        Int       @id @default(autoincrement())
  companyId Int       @unique
  planId    Int
  startDate DateTime  @default(now())
  endDate   DateTime?
  active    Boolean   @default(true)

  company Company @relation(fields: [companyId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  companyId Int?
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
}

model UsageRecord {
  id           Int      @id @default(autoincrement())
  companyId    Int
  year         Int      // ano de referência
  month        Int      // mês de referência
  jobsUsed     Int      @default(0)
  aiResumeUsed Int      @default(0)
  aiSalaryUsed Int      @default(0)
  interviewsUsed Int    @default(0)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, year, month])
}
